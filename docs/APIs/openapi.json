        "type": "object",
        "additionalProperties": false
      },
      "AgentExecutionMetadata": {
        "description": "Documentation DTOs shared by the representative agent controllers.\n\nThese interfaces intentionally mirror the stable request and response shapes\nexposed by the Dialogue, Web, and Knowledge agents so tsoa can generate a\nreadable OpenAPI contract for Phase 1 of the documentation system.",
        "properties": {
          "duration": {
            "type": "number",
            "format": "double",
            "description": "Time spent fulfilling the request, in milliseconds."
          },
          "retryCount": {
            "type": "number",
            "format": "double",
            "description": "Number of retry attempts applied before the final response."
          }
        },
        "required": [
          "duration",
          "retryCount"
        ],
        "type": "object",
        "additionalProperties": false
      },

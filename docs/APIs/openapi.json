    "schemas": {
      "MemoryUsageSnapshot": {
        "properties": {
          "rss": {
            "type": "number",
            "format": "double",
            "description": "Resident set size in bytes."
          },
          "heapTotal": {
            "type": "number",
            "format": "double",
            "description": "Total V8 heap size in bytes."
          },
          "heapUsed": {
            "type": "number",
            "format": "double",
            "description": "Used V8 heap size in bytes."
          },
          "external": {
            "type": "number",
            "format": "double",
            "description": "External memory tracked by Node.js in bytes."
          },
          "arrayBuffers": {
            "type": "number",
            "format": "double",
            "description": "Array buffer memory in bytes."
          }
        },
        "type": "object",
        "additionalProperties": false
      },
      "AgentHealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "healthy",
              "degraded",
              "unhealthy"
            ],
            "description": "High-level health classification used by monitoring and self-healing."
          },
          "uptime": {
            "type": "number",
            "format": "double",
            "description": "Agent uptime, in seconds."
          },
          "memory": {
            "$ref": "#/components/schemas/MemoryUsageSnapshot",
            "description": "Process memory snapshot when the health probe was served."
          },
          "requestCount": {
            "type": "number",
            "format": "double",
            "description": "Count of requests seen since process start, when available."
          },
          "errorCount": {
            "type": "number",
            "format": "double",
            "description": "Count of failed requests seen since process start, when available."
          },
          "avgResponseTime": {
            "type": "number",
            "format": "double",
            "description": "Average response time tracked by the enhanced base agent."
          }
        },
        "required": [
          "status",
          "uptime"
        ],
        "type": "object",
        "additionalProperties": false
      },
      "AgentMetricsResponse": {
        "properties": {

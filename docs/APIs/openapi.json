          "explanation": {
            "type": "string",
            "description": "Narrative explanation of the verdict."
          },
          "timestamp": {
            "type": "string",
            "description": "Timestamp recorded when the fact-check completed."
          }
        },
        "required": [
          "claim",
          "verdict",
          "confidence",
          "confirmingSources",
          "contradictingSources",
          "neutralSources",
          "explanation",
          "timestamp"

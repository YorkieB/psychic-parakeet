  "info": {
    "title": "Jarvis Representative Agent API",
    "version": "4.0.0",
    "description": "Phase 1 OpenAPI surface generated from representative Dialogue, Web, and Knowledge controllers for the Jarvis documentation system foundation.",
    "contact": {}
  },
  "paths": {
    "/api/web/health": {
      "get": {
        "operationId": "getWebHealth",
        "responses": {
          "200": {
            "description": "Web agent health returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentHealthResponse"
                }
              }
            }
          }
        },
        "description": "Get the current health snapshot for the Web agent.",
        "tags": [
          "Web"
        ],
        "security": [],
        "parameters": []
      }
    },
    "/api/web/metrics": {
      "get": {
        "operationId": "getWebMetrics",
        "responses": {
          "200": {
            "description": "Web agent metrics returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMetricsResponse"
                }
              }
            }
          }
        },
        "description": "Get rolling search and performance metrics for the Web agent.",
        "tags": [
          "Web"
        ],
        "security": [],
        "parameters": []
      }
    },
    "/api/web/search": {
      "post": {
        "operationId": "searchWithWebAgent",
        "responses": {
          "200": {
            "description": "Search results returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebSearchResponseEnvelope"
                },
                "examples": {
                  "Example 1": {
                    "value": {
                      "success": true,
                      "data": {
                        "results": [
                          {
                            "title": "Jarvis documentation system foundations",
                            "url": "https://example.com/jarvis-docs",
                            "snippet": "A representative result returned by the Web agent.",
                            "hostname": "example.com"
                          }
                        ],
                        "query": "jarvis documentation system foundations",
                        "resultCount": 1,
                        "timestamp": "2026-03-22T11:05:24.498Z",
                        "source": "google",
                        "duration": 231
                      },
                      "metadata": {
                        "duration": 231,
                        "retryCount": 0
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "The request body is missing a query",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentErrorEnvelope"
                }
              }
            }
          },
          "500": {
            "description": "The Web agent search request failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentErrorEnvelope"
                }
              }
            }
          }
        },
        "description": "Run a web search through the configured provider and return normalized\nsearch results for downstream agent consumption.",
        "tags": [
          "Web"
        ],
        "security": [],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebSearchRequest"
              }
            }
          }
        }
      }
    },
    "/api/knowledge/health": {
      "get": {
        "operationId": "getKnowledgeHealth",
        "responses": {
          "200": {
            "description": "Knowledge agent health returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentHealthResponse"
                }
              }
            }
          }
        },
        "description": "Get the current health snapshot for the Knowledge agent.",
        "tags": [
          "Knowledge"
        ],
        "security": [],
        "parameters": []
      }
    },
    "/api/knowledge/metrics": {
      "get": {
        "operationId": "getKnowledgeMetrics",
        "responses": {
          "200": {
            "description": "Knowledge agent metrics returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentMetricsResponse"
                }
              }
            }
          }
        },
        "description": "Get rolling synthesis and performance metrics for the Knowledge agent.",
        "tags": [
          "Knowledge"
        ],
        "security": [],
        "parameters": []
      }
    },
    "/api/knowledge/research": {
      "post": {
        "operationId": "researchWithKnowledgeAgent",
        "responses": {
          "200": {
            "description": "Research result returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KnowledgeResearchResponseEnvelope"
                },
                "examples": {
                  "Example 1": {
                    "value": {
                      "success": true,
                      "data": {
                        "topic": "documentation drift prevention",
                        "summary": "Documentation drift is reduced by generating docs from source code.",
                        "sources": [
                          {
                            "title": "Generated documentation guide",
                            "url": "https://example.com/generated-docs",
                            "snippet": "A representative source snippet.",
                            "relevance": 0.93,
                            "hostname": "example.com"
                          }
                        ],
                        "keyPoints": [
                          "Generate API reference from code.",
                          "Keep architecture rationale in ADRs."
                        ],
                        "confidence": 0.86,
                        "timestamp": "2026-03-22T11:05:24.498Z",
                        "queriesUsed": 3,
                        "depth": "medium"
                      },
                      "metadata": {
                        "duration": 618,
                        "retryCount": 0
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "The request body is missing a topic",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentErrorEnvelope"
                }
              }
            }
          },
          "500": {
            "description": "The Knowledge agent research request failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentErrorEnvelope"
                }
              }
            }
          }
        },
        "description": "Research a topic from multiple angles and synthesize a citation-friendly\nanswer from the highest-value retrieved sources.",
        "tags": [
          "Knowledge"
        ],
        "security": [],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/KnowledgeResearchRequest"
              }

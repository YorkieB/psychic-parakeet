{
	"name": "jarvis-desktop",
	"version": "1.1.0",
	"description": "Jarvis AI Assistant Desktop Application",
	"main": "dist/main/main/index.js",
	"author": "Yorkie",
	"license": "MIT",
	"scripts": {
		"dev": "npm run build:main && npm run build:preload && npx cross-env VITE_DEV_PORT=5173 npx concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
		"dev:vite": "vite",
		"dev:electron": "npx wait-on http://localhost:5173 -t 60000 && npx cross-env NODE_ENV=development VITE_DEV_PORT=5173 npx electron .",
		"build": "npm run build:renderer && npm run build:main && npm run build:preload",
		"build:renderer": "vite build",
		"build:main": "tsc -p tsconfig.electron.json --outDir dist/main",
		"build:preload": "tsc src/preload/index.ts --outDir dist/preload --module commonjs --target ES2020 --moduleResolution node --esModuleInterop --skipLibCheck",
		"package": "npm run build && electron-builder",
		"package:win": "npm run build && electron-builder --win",
		"package:mac": "npm run build && electron-builder --mac",
		"package:linux": "npm run build && electron-builder --linux",
		"postinstall": "echo Skipping electron-builder install-app-deps"
	},
	"dependencies": {
		"@monaco-editor/react": "^4.7.0",
		"@types/howler": "^2.2.12",
		"axios": "^1.7.0",
		"chalk": "^4.1.2",
		"date-fns": "^3.0.0",
		"electron-store": "^8.1.0",
		"howler": "^2.2.3",
		"monaco-editor": "^0.55.1",
		"socket.io-client": "^4.7.0"
	},
	"devDependencies": {
		"@radix-ui/react-dialog": "^1.0.5",
		"@radix-ui/react-dropdown-menu": "^2.0.6",
		"@radix-ui/react-slider": "^1.1.2",
		"@radix-ui/react-switch": "^1.0.3",
		"@types/node": "^20.10.0",
		"@types/react": "^18.3.28",
		"@types/react-dom": "^18.3.7",
		"@vitejs/plugin-react": "^4.3.0",
		"autoprefixer": "^10.4.0",
		"concurrently": "^8.2.0",
		"cross-env": "^7.0.3",
		"electron": "^31.0.0",
		"electron-builder": "^24.13.0",
		"framer-motion": "^10.18.0",
		"lucide-react": "^0.300.0",
		"postcss": "^8.4.0",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"recharts": "^2.10.0",
		"tailwindcss": "^3.4.0",
		"typescript": "^5.5.0",
		"vite": "5.4",
		"wait-on": "^7.2.0",
		"zustand": "^4.4.0"
	},
	"build": {
		"appId": "com.jarvis.desktop",
		"productName": "Jarvis AI Assistant",
		"directories": {
			"output": "release"
		},
		"files": [
			"dist/**/*",
			"public/**/*",
			"package.json"
		],
		"win": {
			"target": "nsis",
			"icon": "public/icons/icon.ico",
			"sign": null,
			"signingHashAlgorithms": []
		},
		"mac": {
			"target": "dmg",
			"icon": "public/icons/icon.icns"
		},
		"linux": {
			"target": "AppImage",
			"icon": "public/icons/icon.png"
		}
	}
}

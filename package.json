{
  "name": "jarvis-orchestrator",
  "version": "4.0.0",
  "description": "Jarvis v4 Multi-Agent AI Assistant with Self-Healing Infrastructure",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --expose-gc dist/index.js",
    "dev": "ts-node --transpile-only src/index.ts",
    "dev:quick": "ts-node --transpile-only src/quick-start.ts",
    "dev:spark": "ts-node --transpile-only src/spark-start.ts",
    "dev:all": "npx concurrently --names SPARK,DASH --prefix-colors cyan,magenta \"npx ts-node --transpile-only src/spark-start.ts\" \"npm --prefix dashboard run dev\"",
    "dev:watch": "nodemon --watch src --ext ts --exec \"ts-node --transpile-only src/index.ts\" --delay 2",
    "dev:stable": "node --expose-gc -r ts-node/register src/index.ts",
    "test": "ts-node --transpile-only tests/automated-test-runner.ts",
    "test:jest": "jest",
    "test:bash": "bash tests/endpoint-tests.sh",
    "test:postman": "newman run tests/jarvis-postman-collection.json",
    "test:quick": "ts-node --transpile-only tests/quick-test.ts",
    "test:load": "artillery run tests/load-test.yml",
    "test:watch": "nodemon --exec 'ts-node --transpile-only' tests/automated-test-runner.ts",
    "test:health": "ts-node --transpile-only tests/health-monitoring.ts",
    "test:smoke": "ts-node --transpile-only tests/smoke-test-suite.ts",
    "test:performance": "ts-node --transpile-only tests/performance-benchmark.ts",
    "test:security": "ts-node --transpile-only test-security.ts",
    "test:stress": "ts-node --transpile-only tests/stress-test.ts",
    "test:recovery": "ts-node --transpile-only tests/recovery-test.ts",
    "test:integration": "ts-node --transpile-only tests/integration-test.ts",
    "test:data-integrity": "ts-node --transpile-only tests/data-integrity-test.ts",
    "test:compatibility": "ts-node --transpile-only tests/api-compatibility-test.ts",
    "test:sensors": "npx ts-node --transpile-only tests/sensor-health-tests.ts",
    "test:ui-sensors": "npx ts-node --transpile-only tests/ui-sensor-tests.ts",
    "test:all": "npx ts-node --transpile-only tests/comprehensive-test-runner.ts",
    "test:critical": "ts-node --transpile-only tests/comprehensive-test-runner.ts",
    "monitor:health": "ts-node --transpile-only tests/health-monitoring.ts",
    "predeploy": "npm run test:all && npm run lint && bash scripts/pre-release-check.sh",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "lint:all": "ts-node --transpile-only scripts/lint-all.ts",
    "lint:eslint": "eslint \"src/**/*.ts\"",
    "lint:prettier": "prettier --check \"src/**/*.ts\"",
    "lint:types": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "fix": "bash scripts/fix-all.sh",
    "fix:eslint": "eslint \"src/**/*.ts\" --fix",
    "fix:prettier": "prettier --write \"src/**/*.ts\"",
    "analyze": "ts-node --transpile-only scripts/code-metrics.ts",
    "analyze:deps": "npm audit",
    "analyze:circular": "madge --circular --extensions ts src/",
    "analyze:duplicate": "jscpd src/",
    "analyze:complexity": "eslint \"src/**/*.ts\" --rule \"complexity: [error, 10]\"",
    "prepare": "echo 'Skipping husky install'",
    "precommit": "lint-staged && npm run typecheck",
    "prepush": "npm run quality",
    "quality": "npm run lint:all && npm run analyze && npm run test:quick",
    "setup:quality": "bash scripts/setup-quality-tools.sh",
    "pre-release": "bash scripts/pre-release-check.sh",
    "migrate": "ts-node scripts/run-migration.ts",
    "pm2:start": "pm2 start ecosystem.config.js --only jarvis-backend",
    "pm2:dev": "pm2 start ecosystem.config.js --only jarvis-dev",
    "pm2:stop": "pm2 stop all",
    "pm2:restart": "pm2 restart all",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "pm2:delete": "pm2 delete all",
    "pm2:startup": "pm2 startup",
    "pm2:save": "pm2 save",
    "stable": "npm run build && npm run pm2:start",
    "stable:dev": "pm2 start ecosystem.config.js --only jarvis-dev",
    "test:endpoints": "ts-node tests/test-runner.ts",
    "test:automated": "ts-node tests/automated-test-runner.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@aws-sdk/client-s3": "^3.893.0",
    "@google-cloud/local-auth": "^3.0.1",
    "@huggingface/inference": "^4.13.14",
    "@monaco-editor/react": "^4.7.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "axios": "^1.13.4",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "google-auth-library": "^9.0.0",
    "googleapis": "^171.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "monaco-editor": "^0.55.1",
    "node-fetch": "^3.3.2",
    "openai": "^4.20.0",
    "pg": "^8.11.3",
    "plaid": "^41.1.0",
    "socket.io": "^4.7.2",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.30",
    "@types/pg": "^8.16.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "artillery": "^2.0.0",
    "chalk": "^4.1.2",
    "concurrently": "^9.2.1",
    "eslint": "^8.55.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-security": "^2.1.0",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "jscpd": "^3.5.0",
    "lint-staged": "^15.0.0",
    "madge": "^6.1.0",
    "newman": "^6.0.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}

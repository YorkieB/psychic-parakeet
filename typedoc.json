{
  "entryPoints": [
    "src/agents/index.ts",
    "src/orchestrator/index.ts",
    "src/security/index.ts",
    "src/self-healing/index.ts",
    "src/reliability/index.ts",
    "src/knowledge/index.ts",
    "src/voice/index.ts",
    "src/dashboard/index.ts",
    "src/shared/index.ts"
  ],
  "entryPointStrategy": "resolve",
  "name": "Jarvis Internal API Reference",
  "out": "docs/API-REFERENCE",
  "exclude": ["tests", "node_modules/**", "**/*.d.ts"],
  "cleanOutputDir": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "includeVersion": true,
  "sort": ["source-order"],
  "categoryOrder": [
    "Core",
    "Agents",
    "Orchestrator",
    "Security",
    "Self-Healing",
    "Knowledge",
    "Voice",
    "Dashboard",
    "Utilities",
    "Logging"
  ],
  "blockTags": [
    "@param",
    "@returns",
    "@typeParam",
    "@example",
    "@remarks",
    "@throws",
    "@defaultValue",
    "@ts-expect-error",
    "@agent",
    "@domain",
    "@reliabilityThreshold"
  ],
  "modifierTags": ["@critical", "@internal", "@experimental"],
  "plugin": [],
  "readme": "none",
  "navigationLinks": {
    "Architecture ADRs": "../ARCHITECTURE/",
    "OpenAPI Explorer": "../APIs/index.html"
  },
  "validation": {
    "notExported": false,
    "invalidLink": true,
    "invalidPath": true,
    "rewrittenLink": true,
    "notDocumented": false,
    "unusedMergeModuleWith": true
  },
  "visibilityFilters": {
    "protected": true,
    "private": false,
    "@internal": false
  }
}
